NODE_ENV=development
HOST=0.0.0.0
PORT=8787
LOG_LEVEL=info
APP_VERSION=1.0.0
MAX_BODY_BYTES=1048576

# Use local SQLite file for v1
DATABASE_URL=./data/screener.db

# Scan behavior
ENABLE_AUTO_SCAN=true
SCAN_INTERVAL_SEC=90
DEXSCREENER_MAX_TOKENS=40
MIN_LIQUIDITY_USD=15000
MIN_VOLUME_24H_USD=25000
MAX_RISK_SCORE=45
MIN_OPPORTUNITY_SCORE=60

# Optional fallback source
BIRDEYE_API_KEY=
HELIUS_API_KEY=

# Optional future online DB config
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram (backend-only secrets)
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_DRY_RUN_SEND=false

# Public links used in alert messages
APP_BASE_URL=http://localhost:8787
